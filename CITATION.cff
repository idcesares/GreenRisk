version: 0.1.0
date-released: "2026-07-01"
url: "https://github.com/idcesares/GreenRisk"
repository-code: "https://github.com/idcesares/GreenRisk"
license: Apache-2.0
keywords:
  - greenwashing
  - climate disclosure
  - ESG
  - explainable AI
  - fuzzy logic
  - Mamdani inference
  - ClimateBERT
  - natural language processing
  - provenance
  - PROV-O
  - TCFD
